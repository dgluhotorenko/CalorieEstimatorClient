<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ============================================================
         Sprig — brand color tokens (Direction A: Fresh & Airy)
         See CalorieEstimatorDesign/handoff/DESIGN.md §2
         ============================================================ -->

    <!-- Brand -->
    <Color x:Key="Brand">#1B9D57</Color>
    <Color x:Key="BrandStrong">#0E7A41</Color>
    <Color x:Key="BrandDeep">#0C5C33</Color>
    <Color x:Key="BrandTint">#E6F3EA</Color>
    <Color x:Key="BrandInk">#0B3D23</Color>
    <Color x:Key="BrandOnDark">#34C77B</Color>

    <!-- Surfaces -->
    <Color x:Key="Bg">#F4F6F0</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="Surface2">#EEF1E8</Color>

    <!-- Ink / text -->
    <Color x:Key="Ink">#181B16</Color>
    <Color x:Key="Ink2">#5B635A</Color>
    <Color x:Key="Ink3">#959C90</Color>

    <!-- Lines -->
    <Color x:Key="Line">#E4E8DD</Color>
    <Color x:Key="LineSoft">#EDF0E8</Color>

    <!-- Macros -->
    <Color x:Key="Protein">#8B7BD8</Color>
    <Color x:Key="ProteinTint">#ECE8FA</Color>
    <Color x:Key="Fat">#E68A6B</Color>
    <Color x:Key="FatTint">#FBEAE3</Color>
    <Color x:Key="Carbs">#3DAEA4</Color>
    <Color x:Key="CarbsTint">#E0F2F0</Color>

    <!-- Dark theme -->
    <Color x:Key="DarkBg">#0F130E</Color>
    <Color x:Key="DarkSurface">#161C13</Color>
    <Color x:Key="DarkSurface2">#1E261A</Color>
    <Color x:Key="DarkLine">#2A3326</Color>
    <Color x:Key="DarkLineSoft">#232B1F</Color>
    <Color x:Key="DarkInk">#ECEFE8</Color>
    <Color x:Key="DarkInk2">#A7B0A0</Color>
    <Color x:Key="DarkInk3">#6E766A</Color>

    <!-- Convenience brushes -->
    <SolidColorBrush x:Key="BrandBrush" Color="{StaticResource Brand}" />
    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource Bg}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />

    <!-- Hero gradient (Brand → BrandDeep, ~150°) -->
    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="0.5,1">
        <GradientStop Color="{StaticResource Brand}" Offset="0.0" />
        <GradientStop Color="{StaticResource BrandDeep}" Offset="1.0" />
    </LinearGradientBrush>

    <!-- ============================================================
         Legacy/template aliases — kept so the default control styles
         in Styles.xaml keep resolving. Primary is remapped to Brand
         so stock MAUI controls inherit the new green automatically.
         ============================================================ -->
    <Color x:Key="Primary">#1B9D57</Color>
    <Color x:Key="PrimaryDark">#34C77B</Color>
    <Color x:Key="PrimaryDarkText">#242424</Color>
    <Color x:Key="Secondary">#E6F3EA</Color>
    <Color x:Key="SecondaryDarkText">#0E7A41</Color>
    <Color x:Key="Tertiary">#0C5C33</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#1B9D57</Color>
    <Color x:Key="MidnightBlue">#181B16</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>

    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>