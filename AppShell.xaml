<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CalorieClient.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:CalorieClient.Views"
    Title="CalorieClient">

    <TabBar>
        <ShellContent Title="Analyze" Icon="dotnet_bot.png"
                      ContentTemplate="{DataTemplate views:MainPage}"
                      Route="MainPage"/>

        <ShellContent Title="History" Icon="dotnet_bot.png"
                      ContentTemplate="{DataTemplate views:HistoryPage}"
                      Route="HistoryPage"/>
    </TabBar>

</Shell>
