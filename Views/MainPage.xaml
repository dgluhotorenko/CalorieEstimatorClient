<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieClient.ViewModels"
             xmlns:converters="clr-namespace:CalorieClient.Views.Converters"
             xmlns:controls="clr-namespace:CalorieClient.Views.Controls"
             xmlns:models="clr-namespace:CalorieClient.Models"
             x:Class="CalorieClient.Views.MainPage"
             x:DataType="vm:MainViewModel"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource DarkBg}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *">

        <!-- App bar -->
        <controls:AppBar Grid.Row="0"/>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="16" Padding="20,8,20,28">

                <!-- Screen title -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Analyze a meal" Style="{StaticResource ScreenTitle}"/>
                    <Label Text="Snap a photo — get calories and macros in seconds."
                           Style="{StaticResource Body}"/>
                </VerticalStackLayout>

                <!-- Photo dropzone -->
                <Border StrokeShape="RoundRectangle 20"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Line}, Dark={StaticResource DarkLine}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface2}, Dark={StaticResource DarkSurface2}}"
                        HeightRequest="320">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickImageCommand}"/>
                    </Border.GestureRecognizers>
                    <Grid>
                        <!-- Placeholder -->
                        <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="14"
                                             IsVisible="{Binding HasImage, Converter={StaticResource InvertedBoolConverter}}">
                            <Image Source="ic_camera_muted.png" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center"/>
                            <Label Text="TAP TO ADD A PHOTO" Style="{StaticResource SectionLabel}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>

                        <!-- Selected image -->
                        <Image Source="{Binding ImagePath}" Aspect="AspectFill" IsVisible="{Binding HasImage}"/>

                        <!-- Busy overlay -->
                        <Grid IsVisible="{Binding IsBusy}" BackgroundColor="#660C5C33">
                            <VerticalStackLayout VerticalOptions="Center" Spacing="12">
                                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" HeightRequest="36"/>
                                <Label Text="Analyzing ingredients…" TextColor="White"
                                       FontFamily="HankenSemiBold" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Details field -->
                <Border StrokeShape="RoundRectangle 15"
                        StrokeThickness="1"
                        Stroke="{AppThemeBinding Light={StaticResource Line}, Dark={StaticResource DarkLine}}"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark={StaticResource DarkSurface}}"
                        Padding="14,2">
                    <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10">
                        <Image Grid.Column="0" Source="ic_details.png" HeightRequest="20" WidthRequest="20" VerticalOptions="Center"/>
                        <Entry Grid.Column="1"
                               Placeholder="Add details — sauce, sides, portion…"
                               Text="{Binding UserNotes}"
                               Style="{StaticResource DetailsEntry}"/>
                    </Grid>
                </Border>

                <!-- Step 1 actions — no photo yet -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12"
                      IsVisible="{Binding HasImage, Converter={StaticResource InvertedBoolConverter}}">
                    <Button Grid.Column="0" Text="Camera"
                            Command="{Binding TakePhotoCommand}"
                            Style="{StaticResource PrimaryButton}"
                            ImageSource="ic_camera_white.png"
                            ContentLayout="Left,9"/>
                    <Button Grid.Column="1" Text="Gallery"
                            Command="{Binding PickImageCommand}"
                            Style="{StaticResource OutlineButton}"
                            ImageSource="ic_gallery_ink.png"
                            ContentLayout="Left,9"/>
                </Grid>

                <!-- Step 2 actions — photo staged, ready to estimate -->
                <VerticalStackLayout IsVisible="{Binding HasImage}" Spacing="12">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Button Grid.Column="0" Text="Retake"
                                Command="{Binding TakePhotoCommand}"
                                Style="{StaticResource OutlineButton}"
                                ImageSource="ic_camera_ink.png"
                                ContentLayout="Left,9"/>
                        <Button Grid.Column="1" Text="Gallery"
                                Command="{Binding PickImageCommand}"
                                Style="{StaticResource OutlineButton}"
                                ImageSource="ic_gallery_ink.png"
                                ContentLayout="Left,9"/>
                    </Grid>
                    <Button Text="Estimate calories"
                            Command="{Binding EstimateCaloriesCommand}"
                            Style="{StaticResource PrimaryButton}"
                            HeightRequest="54"/>
                </VerticalStackLayout>

                <!-- Results -->
                <VerticalStackLayout IsVisible="{Binding ShowResults}" Spacing="16" Margin="0,4,0,0">

                    <!-- Hero result card -->
                    <Border Style="{StaticResource HeroCard}"
                            Background="{StaticResource HeroGradient}"
                            IsVisible="{Binding AnalysisResult.IsFood}">
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, Auto, Auto" ColumnSpacing="12" RowSpacing="0">

                            <Label Grid.Row="0" Grid.Column="0" Text="ESTIMATED TOTAL"
                                   Style="{StaticResource SectionLabel}" TextColor="#BFE6CF"/>

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding AnalysisResult.DishName}"
                                   TextColor="White" FontFamily="HankenExtraBold" FontSize="22"
                                   CharacterSpacing="-0.4" Margin="0,4,0,0"
                                   MaxLines="2" LineBreakMode="TailTruncation"/>

                            <!-- Confidence chip -->
                            <Border Grid.Row="2" Grid.Column="0"
                                    StrokeThickness="0"
                                    BackgroundColor="#29FFFFFF"
                                    HorizontalOptions="Start"
                                    Padding="10,5"
                                    Margin="0,12,0,0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="999"/>
                                </Border.StrokeShape>
                                <HorizontalStackLayout Spacing="6">
                                    <Image Source="ic_check_white.png" HeightRequest="13" WidthRequest="13" VerticalOptions="Center"/>
                                    <Label Text="{Binding AnalysisResult.ConfidenceScore, StringFormat='Confidence · {0}/10'}"
                                           TextColor="White" FontFamily="HankenBold" FontSize="12"/>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Macro legend -->
                            <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="7" Margin="0,14,0,0">
                                <HorizontalStackLayout Spacing="8">
                                    <Ellipse Fill="{StaticResource Protein}" WidthRequest="9" HeightRequest="9" VerticalOptions="Center"/>
                                    <Label Text="Protein" TextColor="#CFE9D9" FontFamily="HankenMedium" FontSize="13" WidthRequest="54"/>
                                    <Label Text="{Binding AnalysisResult.TotalProtein, StringFormat='{0:F0} g'}" TextColor="White" FontFamily="HankenBold" FontSize="13"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="8">
                                    <Ellipse Fill="{StaticResource Fat}" WidthRequest="9" HeightRequest="9" VerticalOptions="Center"/>
                                    <Label Text="Fat" TextColor="#CFE9D9" FontFamily="HankenMedium" FontSize="13" WidthRequest="54"/>
                                    <Label Text="{Binding AnalysisResult.TotalFat, StringFormat='{0:F0} g'}" TextColor="White" FontFamily="HankenBold" FontSize="13"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="8">
                                    <Ellipse Fill="{StaticResource Carbs}" WidthRequest="9" HeightRequest="9" VerticalOptions="Center"/>
                                    <Label Text="Carbs" TextColor="#CFE9D9" FontFamily="HankenMedium" FontSize="13" WidthRequest="54"/>
                                    <Label Text="{Binding AnalysisResult.TotalCarbs, StringFormat='{0:F0} g'}" TextColor="White" FontFamily="HankenBold" FontSize="13"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <!-- Donut -->
                            <controls:DonutChartView Grid.Row="0" Grid.RowSpan="4" Grid.Column="1"
                                                     Protein="{Binding AnalysisResult.TotalProtein}"
                                                     Fat="{Binding AnalysisResult.TotalFat}"
                                                     Carbs="{Binding AnalysisResult.TotalCarbs}"
                                                     CenterText="{Binding AnalysisResult.TotalCalories, StringFormat='{0}'}"
                                                     WidthRequest="124" HeightRequest="124"
                                                     VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <!-- Not food -->
                    <Border Style="{StaticResource Card}"
                            IsVisible="{Binding AnalysisResult.IsFood, Converter={StaticResource InvertedBoolConverter}}">
                        <Label Text="This doesn't look like food. Try another photo."
                               Style="{StaticResource Body}" TextColor="{AppThemeBinding Light={StaticResource Ink}, Dark={StaticResource DarkInk}}"
                               HorizontalOptions="Center"/>
                    </Border>

                    <!-- Ingredients -->
                    <Label Style="{StaticResource SectionLabel}"
                           IsVisible="{Binding AnalysisResult.IsFood}"
                           Text="{Binding AnalysisResult.Ingredients.Count, StringFormat='Ingredients · {0}'}"/>

                    <CollectionView ItemsSource="{Binding AnalysisResult.Ingredients}"
                                    IsVisible="{Binding AnalysisResult.IsFood}">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Ingredient">
                                <Border Style="{StaticResource Card}">
                                    <VerticalStackLayout Spacing="14">
                                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                                            <Label Grid.Column="0" Text="{Binding Name}"
                                                   Style="{StaticResource CardTitle}"
                                                   LineBreakMode="TailTruncation" MaxLines="1"
                                                   VerticalOptions="Center"/>
                                            <Label Grid.Column="1" VerticalOptions="Center"
                                                   Text="{Binding Calories, StringFormat='{0} kcal'}"
                                                   FontFamily="HankenBold" FontSize="14"
                                                   TextColor="{AppThemeBinding Light={StaticResource BrandStrong}, Dark={StaticResource BrandOnDark}}"/>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                                            <!-- Protein -->
                                            <VerticalStackLayout Grid.Column="0" Spacing="5">
                                                <Label Text="Protein" FontFamily="HankenMedium" FontSize="11.5" TextColor="{AppThemeBinding Light={StaticResource Ink3}, Dark={StaticResource DarkInk3}}"/>
                                                <Label Text="{Binding Protein, StringFormat='{0:F0}g'}" FontFamily="HankenBold" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource Ink}, Dark={StaticResource DarkInk}}"/>
                                                <Border StrokeThickness="0" HeightRequest="5" BackgroundColor="{StaticResource ProteinTint}">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="999"/></Border.StrokeShape>
                                                    <ProgressBar Progress="{Binding Protein, Converter={converters:MacroToProgressConverter Max=50}}"
                                                                 ProgressColor="{StaticResource Protein}" BackgroundColor="Transparent"/>
                                                </Border>
                                            </VerticalStackLayout>
                                            <!-- Fat -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                                <Label Text="Fat" FontFamily="HankenMedium" FontSize="11.5" TextColor="{AppThemeBinding Light={StaticResource Ink3}, Dark={StaticResource DarkInk3}}"/>
                                                <Label Text="{Binding Fat, StringFormat='{0:F0}g'}" FontFamily="HankenBold" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource Ink}, Dark={StaticResource DarkInk}}"/>
                                                <Border StrokeThickness="0" HeightRequest="5" BackgroundColor="{StaticResource FatTint}">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="999"/></Border.StrokeShape>
                                                    <ProgressBar Progress="{Binding Fat, Converter={converters:MacroToProgressConverter Max=50}}"
                                                                 ProgressColor="{StaticResource Fat}" BackgroundColor="Transparent"/>
                                                </Border>
                                            </VerticalStackLayout>
                                            <!-- Carbs -->
                                            <VerticalStackLayout Grid.Column="2" Spacing="5">
                                                <Label Text="Carbs" FontFamily="HankenMedium" FontSize="11.5" TextColor="{AppThemeBinding Light={StaticResource Ink3}, Dark={StaticResource DarkInk3}}"/>
                                                <Label Text="{Binding Carbs, StringFormat='{0:F0}g'}" FontFamily="HankenBold" FontSize="17" TextColor="{AppThemeBinding Light={StaticResource Ink}, Dark={StaticResource DarkInk}}"/>
                                                <Border StrokeThickness="0" HeightRequest="5" BackgroundColor="{StaticResource CarbsTint}">
                                                    <Border.StrokeShape><RoundRectangle CornerRadius="999"/></Border.StrokeShape>
                                                    <ProgressBar Progress="{Binding Carbs, Converter={converters:MacroToProgressConverter Max=100}}"
                                                                 ProgressColor="{StaticResource Carbs}" BackgroundColor="Transparent"/>
                                                </Border>
                                            </VerticalStackLayout>
                                        </Grid>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <Label Text="{Binding ResultText}"
                       IsVisible="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                       Style="{StaticResource CaptionMuted}" HorizontalOptions="Center"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
