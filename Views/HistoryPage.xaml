<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CalorieClient.ViewModels"
             xmlns:models="clr-namespace:CalorieClient.Models"
             xmlns:controls="clr-namespace:CalorieClient.Views.Controls"
             x:Class="CalorieClient.Views.HistoryPage"
             x:DataType="vm:HistoryViewModel"
             xmlns:converters="clr-namespace:CalorieClient.Views.Converters"
             BackgroundColor="{AppThemeBinding Light={StaticResource Bg}, Dark={StaticResource DarkBg}}">

    <ContentPage.Resources>
        <converters:InvertedBoolConverter x:Key="InvertedBoolConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- App bar -->
        <controls:AppBar Grid.Row="0"/>

        <!-- Screen title -->
        <Label Grid.Row="1" Text="History" Style="{StaticResource ScreenTitle}" Margin="20,8,20,12"/>

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <Image Source="ic_camera_muted.png" HeightRequest="44" WidthRequest="44" HorizontalOptions="Center" Opacity="0.7"/>
            <Label Text="No analyses yet" Style="{StaticResource CardTitle}" TextColor="{AppThemeBinding Light={StaticResource Ink2}, Dark={StaticResource DarkInk2}}" HorizontalOptions="Center"/>
            <Label Text="Snap a photo of your meal to get started" Style="{StaticResource CaptionMuted}" HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <!-- History list -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Entries}"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="12"/>
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:HistoryEntry">
                    <SwipeView Margin="20,0">
                        <SwipeView.RightItems>
                            <SwipeItems Mode="Execute">
                                <SwipeItem Text="Delete"
                                           BackgroundColor="#E68A6B"
                                           Command="{Binding Source={RelativeSource AncestorType={x:Type vm:HistoryViewModel}}, Path=DeleteEntryCommand}"
                                           CommandParameter="{Binding .}"/>
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border Style="{StaticResource Card}" Padding="14">
                            <Grid ColumnDefinitions="62, *, Auto" ColumnSpacing="14">
                                <!-- Thumbnail -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Surface2}, Dark={StaticResource DarkSurface2}}"
                                        HeightRequest="62" WidthRequest="62"
                                        VerticalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="14"/>
                                    </Border.StrokeShape>
                                    <Image Source="{Binding ImagePath}" Aspect="AspectFill"/>
                                </Border>

                                <!-- Details -->
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                    <Label Text="{Binding DishName}"
                                           Style="{StaticResource CardTitle}"
                                           MaxLines="1" LineBreakMode="TailTruncation"/>

                                    <HorizontalStackLayout Spacing="6">
                                        <Label Text="{Binding TotalCalories, StringFormat='{0} kcal'}"
                                               FontFamily="HankenBold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource BrandStrong}, Dark={StaticResource BrandOnDark}}"/>
                                        <Label Text="{Binding ConfidenceScore, StringFormat='· {0}/10'}"
                                               Style="{StaticResource CaptionMuted}" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="12">
                                        <HorizontalStackLayout Spacing="5">
                                            <Ellipse Fill="{StaticResource Protein}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center"/>
                                            <Label Text="{Binding TotalProtein, StringFormat='{0:F0}g'}" FontFamily="HankenMedium" FontSize="11.5" TextColor="{AppThemeBinding Light={StaticResource Ink2}, Dark={StaticResource DarkInk2}}"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="5">
                                            <Ellipse Fill="{StaticResource Fat}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center"/>
                                            <Label Text="{Binding TotalFat, StringFormat='{0:F0}g'}" FontFamily="HankenMedium" FontSize="11.5" TextColor="{AppThemeBinding Light={StaticResource Ink2}, Dark={StaticResource DarkInk2}}"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="5">
                                            <Ellipse Fill="{StaticResource Carbs}" WidthRequest="8" HeightRequest="8" VerticalOptions="Center"/>
                                            <Label Text="{Binding TotalCarbs, StringFormat='{0:F0}g'}" FontFamily="HankenMedium" FontSize="11.5" TextColor="{AppThemeBinding Light={StaticResource Ink2}, Dark={StaticResource DarkInk2}}"/>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Date -->
                                <Label Grid.Column="2" VerticalOptions="Start"
                                       Text="{Binding AnalyzedAt, StringFormat='{0:MMM d}'}"
                                       Style="{StaticResource CaptionMuted}"/>
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
